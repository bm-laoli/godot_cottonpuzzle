; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "Node2D",
"class": "FlagSwitch",
"language": "GDScript",
"path": "res://objects/FlagSwitch.gd"
}, {
"base": "Resource",
"class": "H2AConfig",
"language": "GDScript",
"path": "res://mini-game/H2AConfig.gd"
}, {
"base": "Interactable",
"class": "H2AStone",
"language": "GDScript",
"path": "res://mini-game/H2AStone.gd"
}, {
"base": "Area2D",
"class": "Interactable",
"language": "GDScript",
"path": "res://objects/Interactable.gd"
}, {
"base": "Resource",
"class": "Item",
"language": "GDScript",
"path": "res://items/item.gd"
}, {
"base": "Sprite",
"class": "Scene",
"language": "GDScript",
"path": "res://scenes/Scene.gd"
}, {
"base": "Interactable",
"class": "SceneItem",
"language": "GDScript",
"path": "res://objects/SceneItem.gd"
}, {
"base": "Interactable",
"class": "Teleporter",
"language": "GDScript",
"path": "res://objects/Teleporter.gd"
} ]
_global_script_class_icons={
"FlagSwitch": "",
"H2AConfig": "",
"H2AStone": "",
"Interactable": "",
"Item": "",
"Scene": "",
"SceneItem": "",
"Teleporter": ""
}

[application]

config/name="Mishidao"
run/main_scene="res://scenes/H1.tscn"
config/icon="res://icon.png"

[autoload]

SceneChanger="*res://globals/SceneChanger.tscn"
Game="*res://globals/Game.gd"
Hud="res://globals/HUD.tscn"

[debug]

gdscript/warnings/unused_signal=false

[display]

window/size/width=1920
window/size/height=1080
window/size/test_width=1536
window/size/test_height=864
window/stretch/mode="2d"
window/stretch/aspect="keep"

[gui]

common/drop_mouse_on_gui_input_disabled=true

[input]

interact={
"deadzone": 0.5,
"events": [ Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"button_mask":0,"position":Vector2( 0, 0 ),"global_position":Vector2( 0, 0 ),"factor":1.0,"button_index":1,"pressed":false,"doubleclick":false,"script":null)
 ]
}

[physics]

common/enable_pause_aware_picking=true

[rendering]

2d/options/ninepatch_mode=0
environment/default_environment="res://default_env.tres"
